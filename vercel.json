{
  "buildCommand": "npm run build",
  "devCommand": "npm run start",
  "installCommand": "npm install",
  "framework": "create-react-app",
  "build": {
    "env": {
      "CI": "false",
      "REACT_APP_API_BASE_URL": "https://client-portfolio-backend.vercel.app"
    }
  },
  "env": {
    "CI": "false",
    "REACT_APP_API_BASE_URL": "https://client-portfolio-backend.vercel.app"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://client-portfolio-backend.vercel.app/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/ads.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ]
}
